<Window x:Class="ChessControlPanel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chess Control Panel"
        Width="340" Height="790"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height"   Value="38"/>
            <Setter Property="Margin"   Value="8,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="Separator">
            <Setter Property="Margin" Value="8,5"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- 0: UE5 상태 -->
            <RowDefinition Height="Auto"/> <!-- 1: Ollama 상태 -->
            <RowDefinition Height="Auto"/> <!-- 2: Ollama 호스트/모델 정보 -->
            <RowDefinition Height="Auto"/> <!-- 3: 구분선 -->
            <RowDefinition Height="Auto"/> <!-- 4: Restart -->
            <RowDefinition Height="Auto"/> <!-- 5: 구분선 -->
            <RowDefinition Height="Auto"/> <!-- 6: AI 섹션 레이블 -->
            <RowDefinition Height="Auto"/> <!-- 7: VS AI 레벨 -->
            <RowDefinition Height="Auto"/> <!-- 8: VS AI White -->
            <RowDefinition Height="Auto"/> <!-- 9: VS AI Black -->
            <RowDefinition Height="Auto"/> <!-- 10: 구분선 -->
            <RowDefinition Height="Auto"/> <!-- 11: AI VS AI 레이블 -->
            <RowDefinition Height="Auto"/> <!-- 12: AI VS AI 흑/백 레벨 선택 -->
            <RowDefinition Height="Auto"/> <!-- 13: AI VS AI 버튼 -->
            <RowDefinition Height="Auto"/> <!-- 14: AI VS AI 상태 -->
            <RowDefinition Height="Auto"/> <!-- 15: 구분선 -->
            <RowDefinition Height="Auto"/> <!-- 16: 마지막 AI 수 디버그 패널 -->
            <RowDefinition Height="Auto"/> <!-- 17: 구분선 -->
            <RowDefinition Height="Auto"/> <!-- 18: 에러 메시지 -->
        </Grid.RowDefinitions>

        <!-- Row 0: UE5 연결 상태 -->
        <Border Grid.Row="0" CornerRadius="4" Padding="8,5" Margin="8,4">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#FFDDDD"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                            <Setter Property="Background" Value="#DDFFDD"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding UeStatusText}" FontWeight="Bold"
                       HorizontalAlignment="Center" FontSize="13"/>
        </Border>

        <!-- Row 1: Ollama 상태 -->
        <Border Grid.Row="1" CornerRadius="4" Padding="8,5" Margin="8,2">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#FFEECC"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsOllamaAlive}" Value="True">
                            <Setter Property="Background" Value="#E8F4FD"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding OllamaStatusText}"
                       HorizontalAlignment="Center" FontSize="11"/>
        </Border>

        <!-- Row 2: Ollama 호스트 / 모델 정보 -->
        <Border Grid.Row="2" Background="#F5F5F5" CornerRadius="4"
                Padding="8,5" Margin="8,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Host : "
                           FontSize="11" Foreground="#555" FontWeight="SemiBold"/>
                <TextBlock Grid.Row="0" Grid.Column="1"
                           Text="{Binding OllamaHostText}"
                           FontSize="11" Foreground="#333" TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Model: "
                           FontSize="11" Foreground="#555" FontWeight="SemiBold"/>
                <TextBlock Grid.Row="1" Grid.Column="1"
                           Text="{Binding OllamaModelText}"
                           FontSize="11" Foreground="#333" TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>

        <Separator Grid.Row="3"/>

        <!-- Row 4: 재시작 -->
        <Button Grid.Row="4" Content="♻  Restart" Click="OnRestart"
                Background="#FFF3CD"/>

        <Separator Grid.Row="5"/>

        <!-- Row 6: VS AI 섹션 레이블 -->
        <TextBlock Grid.Row="6" Text="─── AI 대전 (Ollama LLM) ───"
                   HorizontalAlignment="Center" Foreground="Gray" Margin="0,4"/>

        <!-- Row 7: VS AI 레벨 선택 -->
        <Border Grid.Row="7" Background="#F8F8F8" CornerRadius="4" Margin="8,2" Padding="6,5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="AI 레벨" VerticalAlignment="Center"
                           FontSize="12" Foreground="#444" Margin="0,0,10,0"/>
                <RadioButton Tag="1" GroupName="VsAi" Click="OnAiLevelChanged"
                             IsChecked="{Binding AiLevel1, Mode=OneWay}"
                             Margin="4,0" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="초보" FontSize="12" FontWeight="SemiBold" Foreground="#2E7D32"/>
                        <TextBlock Text="ELO ≈800" FontSize="9" Foreground="#777"/>
                    </StackPanel>
                </RadioButton>
                <RadioButton Tag="2" GroupName="VsAi" Click="OnAiLevelChanged"
                             IsChecked="{Binding AiLevel2, Mode=OneWay}"
                             Margin="4,0" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="중급" FontSize="12" FontWeight="SemiBold" Foreground="#1565C0"/>
                        <TextBlock Text="ELO ≈1600" FontSize="9" Foreground="#777"/>
                    </StackPanel>
                </RadioButton>
                <RadioButton Tag="3" GroupName="VsAi" Click="OnAiLevelChanged"
                             IsChecked="{Binding AiLevel3, Mode=OneWay}"
                             Margin="4,0" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="고급" FontSize="12" FontWeight="SemiBold" Foreground="#6A1B9A"/>
                        <TextBlock Text="ELO 2000+" FontSize="9" Foreground="#777"/>
                    </StackPanel>
                </RadioButton>
            </StackPanel>
        </Border>

        <Button Grid.Row="8" Content="🤖  VS AI — 내가 White"
                Click="OnVsAiWhite" Background="#E8F4FD"/>

        <Button Grid.Row="9" Content="🤖  VS AI — 내가 Black"
                Click="OnVsAiBlack" Background="#F0E8FD"/>

        <Separator Grid.Row="10"/>

        <!-- Row 11: AI VS AI 섹션 레이블 -->
        <TextBlock Grid.Row="11" Text="─── AI VS AI 자동 대전 ───"
                   HorizontalAlignment="Center" Foreground="Gray" Margin="0,4"/>

        <!-- Row 12: AI VS AI 흑/백 레벨 선택 -->
        <Border Grid.Row="12" Background="#F0F0FF" CornerRadius="4" Margin="8,2" Padding="8,6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 백 AI 레벨 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,2">
                    <Border Width="11" Height="11" Background="White"
                            BorderBrush="#888" BorderThickness="1" CornerRadius="2"
                            VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="백 AI" FontSize="12" FontWeight="SemiBold"
                               Foreground="#333" VerticalAlignment="Center" Width="32"/>
                    <RadioButton Content="초보" Tag="1" GroupName="AutoWhite"
                                 Click="OnAutoAiWhiteLevelChanged"
                                 IsChecked="{Binding AutoWhiteLevel1, Mode=OneWay}"
                                 FontSize="11" Margin="6,0,2,0" VerticalAlignment="Center"/>
                    <RadioButton Content="중급" Tag="2" GroupName="AutoWhite"
                                 Click="OnAutoAiWhiteLevelChanged"
                                 IsChecked="{Binding AutoWhiteLevel2, Mode=OneWay}"
                                 FontSize="11" Margin="6,0,2,0" VerticalAlignment="Center"/>
                    <RadioButton Content="고급" Tag="3" GroupName="AutoWhite"
                                 Click="OnAutoAiWhiteLevelChanged"
                                 IsChecked="{Binding AutoWhiteLevel3, Mode=OneWay}"
                                 FontSize="11" Margin="6,0,2,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 흑 AI 레벨 -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,2">
                    <Border Width="11" Height="11" Background="#2C2C2C"
                            CornerRadius="2" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="흑 AI" FontSize="12" FontWeight="SemiBold"
                               Foreground="#333" VerticalAlignment="Center" Width="32"/>
                    <RadioButton Content="초보" Tag="1" GroupName="AutoBlack"
                                 Click="OnAutoAiBlackLevelChanged"
                                 IsChecked="{Binding AutoBlackLevel1, Mode=OneWay}"
                                 FontSize="11" Margin="6,0,2,0" VerticalAlignment="Center"/>
                    <RadioButton Content="중급" Tag="2" GroupName="AutoBlack"
                                 Click="OnAutoAiBlackLevelChanged"
                                 IsChecked="{Binding AutoBlackLevel2, Mode=OneWay}"
                                 FontSize="11" Margin="6,0,2,0" VerticalAlignment="Center"/>
                    <RadioButton Content="고급" Tag="3" GroupName="AutoBlack"
                                 Click="OnAutoAiBlackLevelChanged"
                                 IsChecked="{Binding AutoBlackLevel3, Mode=OneWay}"
                                 FontSize="11" Margin="6,0,2,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 13: AI VS AI 토글 버튼 -->
        <Button Grid.Row="13"
                Content="{Binding AutoPlayButtonText}"
                Click="OnToggleAutoPlay"
                Background="{Binding AutoPlayButtonColor}"/>

        <!-- Row 14: AI VS AI 상태 텍스트 -->
        <TextBlock Grid.Row="14"
                   Text="{Binding AutoPlayStatusText}"
                   HorizontalAlignment="Center"
                   Foreground="#555" FontSize="11" Margin="0,2"/>

        <Separator Grid.Row="15"/>

        <!-- Row 16: 마지막 AI 수 디버그 패널 -->
        <Border Grid.Row="16" CornerRadius="4" Padding="8,6" Margin="8,2"
                Background="#F0F4FF"
                Visibility="{Binding LastMoveVisibility}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 헤더 행: 레이블 + 수 + 응답시간 -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="마지막 AI 수  "
                               FontSize="11" Foreground="#555"/>
                    <TextBlock Grid.Column="1" Text="{Binding LastMoveUci}"
                               FontSize="14" FontWeight="Bold" Foreground="#1A237E"
                               FontFamily="Consolas"/>
                    <TextBlock Grid.Column="2" Text="{Binding LastLatencyText}"
                               FontSize="11" Foreground="#777"/>
                </Grid>

                <!-- 레벨 + 폴백 행 -->
                <Grid Grid.Row="1" Margin="0,3,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="레벨: " FontSize="11" Foreground="#555"/>
                        <TextBlock Text="{Binding LastLevelText}" FontSize="11" Foreground="#333"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="폴백: " FontSize="11" Foreground="#555"/>
                        <TextBlock Text="{Binding LastFallbackText}" FontSize="11"
                                   Foreground="{Binding LastFallbackColor}" FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>

                <!-- AI 코멘트 -->
                <TextBlock Grid.Row="2" Text="{Binding LastComment}"
                           FontSize="10" Foreground="#444"
                           TextWrapping="Wrap" FontStyle="Italic"
                           Margin="0,4,0,0"
                           Visibility="{Binding LastCommentVisibility}"/>
            </Grid>
        </Border>

        <Separator Grid.Row="17"/>

        <!-- Row 18: 에러 메시지 -->
        <TextBlock Grid.Row="18" Text="{Binding ErrorText}"
                   Foreground="Red" TextWrapping="Wrap"
                   Margin="8,2" FontSize="11"
                   Visibility="{Binding ErrorVisibility}"/>
    </Grid>
</Window>
