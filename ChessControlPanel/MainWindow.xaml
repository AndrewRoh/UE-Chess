<Window x:Class="ChessControlPanel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chess Control Panel"
        Width="310" Height="540"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height"   Value="38"/>
            <Setter Property="Margin"   Value="8,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="Separator">
            <Setter Property="Margin" Value="8,5"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- 0: UE5 상태 -->
            <RowDefinition Height="Auto"/> <!-- 1: Ollama 상태 -->
            <RowDefinition Height="Auto"/> <!-- 2: 구분선 -->
            <RowDefinition Height="Auto"/> <!-- 3: Restart -->
            <RowDefinition Height="Auto"/> <!-- 4: 구분선 -->
            <RowDefinition Height="Auto"/> <!-- 5: 핫시트 레이블 -->
            <RowDefinition Height="Auto"/> <!-- 6: Start White -->
            <RowDefinition Height="Auto"/> <!-- 7: Start Black -->
            <RowDefinition Height="Auto"/> <!-- 8: 구분선 -->
            <RowDefinition Height="Auto"/> <!-- 9: AI 레이블 -->
            <RowDefinition Height="Auto"/> <!-- 10: AI 레벨 -->
            <RowDefinition Height="Auto"/> <!-- 11: VS AI White -->
            <RowDefinition Height="Auto"/> <!-- 12: VS AI Black -->
            <RowDefinition Height="Auto"/> <!-- 13: 구분선 -->
            <RowDefinition Height="Auto"/> <!-- 14: 에러 메시지 -->
        </Grid.RowDefinitions>

        <!-- Row 0: UE5 연결 상태 -->
        <Border Grid.Row="0" CornerRadius="4" Padding="8,5" Margin="8,4">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#FFDDDD"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                            <Setter Property="Background" Value="#DDFFDD"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding UeStatusText}" FontWeight="Bold"
                       HorizontalAlignment="Center" FontSize="13"/>
        </Border>

        <!-- Row 1: Ollama 상태 -->
        <Border Grid.Row="1" CornerRadius="4" Padding="8,5" Margin="8,2">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#FFEECC"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsOllamaAlive}" Value="True">
                            <Setter Property="Background" Value="#E8F4FD"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding OllamaStatusText}"
                       HorizontalAlignment="Center" FontSize="11"/>
        </Border>

        <Separator Grid.Row="2"/>

        <!-- Row 3: 재시작 -->
        <Button Grid.Row="3" Content="♻  Restart" Click="OnRestart"
                Background="#FFF3CD"/>

        <Separator Grid.Row="4"/>

        <!-- Row 5: 핫시트 섹션 -->
        <TextBlock Grid.Row="5" Text="─── 핫시트 (2인 로컬) ───"
                   HorizontalAlignment="Center" Foreground="Gray" Margin="0,4"/>

        <Button Grid.Row="6" Content="▶  Start as White (핫시트)"
                Click="OnStartWhiteHotseat" Background="#E8F4FD"/>

        <Button Grid.Row="7" Content="▶  Start as Black (핫시트)"
                Click="OnStartBlackHotseat" Background="#F0E8FD"/>

        <Separator Grid.Row="8"/>

        <!-- Row 9: AI 섹션 -->
        <TextBlock Grid.Row="9" Text="─── AI 대전 (Ollama LLM) ───"
                   HorizontalAlignment="Center" Foreground="Gray" Margin="0,4"/>

        <!-- Row 10: AI 레벨 선택 -->
        <StackPanel Grid.Row="10" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,4">
            <TextBlock Text="AI 레벨: " VerticalAlignment="Center" FontSize="13"/>
            <RadioButton Content="1" GroupName="AI" Margin="4,0"
                         IsChecked="{Binding AiLevel1, Mode=OneWay}"
                         Click="OnAiLevelChanged" Tag="1" VerticalAlignment="Center"/>
            <RadioButton Content="2" GroupName="AI" Margin="4,0"
                         IsChecked="{Binding AiLevel2, Mode=OneWay}"
                         Click="OnAiLevelChanged" Tag="2" VerticalAlignment="Center"/>
            <RadioButton Content="3" GroupName="AI" Margin="4,0"
                         IsChecked="{Binding AiLevel3, Mode=OneWay}"
                         Click="OnAiLevelChanged" Tag="3" VerticalAlignment="Center"/>
        </StackPanel>

        <Button Grid.Row="11" Content="🤖  VS AI — 내가 White"
                Click="OnVsAiWhite" Background="#E8F4FD"/>

        <Button Grid.Row="12" Content="🤖  VS AI — 내가 Black"
                Click="OnVsAiBlack" Background="#F0E8FD"/>

        <Separator Grid.Row="13"/>

        <!-- Row 14: 에러 메시지 -->
        <TextBlock Grid.Row="14" Text="{Binding ErrorText}"
                   Foreground="Red" TextWrapping="Wrap"
                   Margin="8,2" FontSize="11"
                   Visibility="{Binding ErrorVisibility}"/>
    </Grid>
</Window>
